# Variables de entorno — DEVELOPMENT
# Cargadas por docker-compose.yml en este mismo directorio.

NODE_ENV=development

# Puerto del dev-server de Angular (host:container)
PORT=4200

# Forzar polling en file watchers — necesario en WSL2 / Docker Desktop
# para que el hot-reload detecte cambios via bind mount.
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
