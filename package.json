  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:gh-pages": "ng build --configuration gh-pages",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build --force --pretty",
    "serve:ssr:MISO-4104-ANGULAR-PRACTICE-ASSESSMENT": "node dist/MISO-4104-ANGULAR-PRACTICE-ASSESSMENT/server/server.mjs"
  },
  "dependencies": {
